{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chapter Evaluation Output",
  "description": "QualityJudge evaluation output written to evaluations/chapter-{C:03d}-eval.json",
  "type": "object",
  "$defs": {
    "reader_score_entry": {
      "type": "object",
      "properties": {
        "score": { "type": "number", "minimum": 1, "maximum": 5 },
        "weight": { "type": "number" },
        "reason": { "type": "string" },
        "evidence": { "type": "string" }
      }
    }
  },
  "required": ["chapter", "eval_used", "metadata"],
  "properties": {
    "chapter": { "type": "integer", "minimum": 1 },
    "eval_used": {
      "type": "object",
      "required": ["contract_verification", "scores", "overall_raw", "overall", "recommendation", "anti_ai", "risk_flags", "reader_evaluation", "overall_weighted", "platform_weights"],
      "properties": {
        "contract_verification": {
          "type": "object",
          "required": ["l1_checks", "l2_checks", "l3_checks", "ls_checks", "platform_hard_gates", "has_violations", "has_warnings"],
          "properties": {
            "l1_checks": { "type": "array" },
            "l2_checks": { "type": "array" },
            "l3_checks": { "type": "array" },
            "ls_checks": { "type": "array" },
            "platform_hard_gates": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["gate_id", "status", "detail"],
                "properties": {
                  "gate_id": { "type": "string", "pattern": "^[a-z]+_ch\\d{3}_" },
                  "status": { "enum": ["pass", "fail", "skipped"] },
                  "detail": { "type": "string" },
                  "fix_suggestion": { "type": ["string", "null"] }
                }
              }
            },
            "has_violations": { "type": "boolean" },
            "has_warnings": { "type": "boolean" }
          }
        },
        "scores": {
          "type": "object",
          "required": ["plot_logic", "character", "immersion", "foreshadowing", "pacing", "style_naturalness", "emotional_impact", "storyline_coherence"],
          "additionalProperties": {
            "type": "object",
            "required": ["score", "weight", "reason", "evidence"],
            "properties": {
              "score": { "type": "number", "minimum": 1, "maximum": 5 },
              "weight": { "type": "number" },
              "reason": { "type": "string" },
              "evidence": { "type": "string" }
            }
          }
        },
        "overall_raw": { "type": "number", "minimum": 1, "maximum": 5 },
        "overall_weighted": { "type": ["number", "null"], "minimum": 1, "maximum": 5 },
        "platform_weights": {
          "type": ["object", "null"],
          "properties": {
            "pacing": { "type": "number" },
            "character": { "type": "number" },
            "immersion": { "type": "number" },
            "foreshadowing": { "type": "number" },
            "plot_logic": { "type": "number" },
            "style_naturalness": { "type": "number" },
            "emotional_impact": { "type": "number" },
            "storyline_coherence": { "type": "number" }
          }
        },
        "overall": { "type": "number", "minimum": 1, "maximum": 5 },
        "recommendation": { "enum": ["pass", "polish", "revise", "review", "rewrite"] },
        "risk_flags": { "type": "array", "items": { "type": "string" } },
        "required_fixes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "target": { "type": "string" },
              "instruction": { "type": "string" }
            }
          }
        },
        "issues": { "type": "array", "items": { "type": "string" } },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "reader_evaluation": {
          "type": ["object", "null"],
          "description": "Track 3 读者参与度评估。null 仅当 Track 3 运行时异常（内部错误）时出现；正常流程必有值。旧 eval 缺失此字段时可通过质量回顾的 Track 3 补全机制回填",
          "properties": {
            "persona": { "type": "string" },
            "reader_scores": {
              "type": "object",
              "properties": {
                "continue_reading": { "$ref": "#/$defs/reader_score_entry" },
                "hook_effectiveness": { "$ref": "#/$defs/reader_score_entry" },
                "skip_urge": { "$ref": "#/$defs/reader_score_entry" },
                "confusion": { "$ref": "#/$defs/reader_score_entry" },
                "empathy": { "$ref": "#/$defs/reader_score_entry" },
                "freshness": { "$ref": "#/$defs/reader_score_entry" }
              }
            },
            "overall_engagement": { "type": "number", "minimum": 1, "maximum": 5 },
            "suspicious_skim_paragraphs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "paragraph_index": { "type": "integer" },
                  "opening_words": { "type": "string" },
                  "reason": { "type": "string" },
                  "severity": { "enum": ["high", "medium"] }
                }
              }
            },
            "emotional_arc": {
              "type": ["object", "null"],
              "properties": {
                "sample_points": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "position_pct": { "type": "number" },
                      "intensity": { "type": "number", "minimum": 1, "maximum": 5 },
                      "emotion": { "type": "string" }
                    }
                  }
                },
                "arc_shape": { "type": "string" },
                "lowest_point_pct": { "type": "number" },
                "peak_point_pct": { "type": "number" },
                "arc_warning": { "type": ["string", "null"] }
              }
            },
            "platform_signal": {
              "type": ["object", "null"],
              "properties": {
                "platform": { "type": "string" },
                "signals": { "type": "object" },
                "one_line_verdict": { "type": "string" }
              }
            },
            "golden_chapter_flags": { "type": "array", "items": { "type": "string" } },
            "reader_feedback": { "type": ["string", "null"] }
          }
        },
        "anti_ai": {
          "type": ["object", "null"],
          "properties": {
            "blacklist_hits": {
              "type": "object",
              "properties": {
                "total_hits": { "type": "integer" },
                "hits_per_kchars": { "type": "number" },
                "top_hits": { "type": "array" },
                "narration_connector_hits": { "type": "integer" },
                "narration_connector_examples": { "type": "array", "items": { "type": "object" } }
              }
            },
            "punctuation_overuse": {
              "type": "object",
              "properties": {
                "em_dash_count": { "type": "integer" },
                "em_dash_per_kchars": { "type": "number" },
                "ellipsis_count": { "type": "integer" },
                "ellipsis_per_kchars": { "type": "number" },
                "exclamation_count": { "type": "integer" },
                "exclamation_per_paragraph_max": { "type": "integer" }
              }
            },
            "sentence_length_stats": {
              "type": ["object", "null"],
              "description": "句长统计。null 当统计工具不可用或章节过短时",
              "properties": {
                "std_dev": { "type": ["number", "null"], "description": "全章句长标准差（字）" },
                "target_range": { "type": ["array", "null"], "items": { "type": "number" }, "description": "目标标准差范围，默认 [8, 18]" },
                "in_range": { "type": ["boolean", "null"], "description": "std_dev 是否落入 target_range" },
                "shortest_sentence": { "type": ["string", "null"], "description": "最短句原文" },
                "longest_sentence_chars": { "type": ["integer", "null"], "description": "最长句字数" }
              }
            },
            "statistical_profile": {
              "type": ["object", "null"],
              "description": "结构化统计指标。null 当统计工具不可用时",
              "properties": {
                "paragraph_length_cv": { "type": ["number", "null"], "description": "段落长度变异系数" },
                "narration_connector_density": { "type": ["number", "null"], "description": "叙述连接词密度（次/千字）" },
                "modifier_repeat_max": { "type": ["integer", "null"], "description": "500字窗口内修饰词最大重复次数" },
                "four_char_idiom_density": { "type": ["number", "null"], "description": "四字词组密度（个/500字）" },
                "adjective_density": { "type": ["number", "null"], "description": "形容词密度（个/300字）" },
                "single_sentence_paragraph_ratio": { "type": ["number", "null"], "description": "单句段落占比（统计参考，不直接参与评分）" },
                "simile_density": { "type": ["number", "null"], "description": "比喻密度（个/千字），精确词条+通用结构合计" },
                "simile_max_per_paragraph": { "type": ["integer", "null"], "description": "单段最大比喻数量" },
                "ai_sentence_pattern_count": { "type": ["integer", "null"], "description": "AI 句式原型命中总数（4类合计）" },
                "dialogue_distinctiveness": { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "对话区分度（去标签后可辨识说话者的比例，0-1）" }
              }
            },
            "detected_humanize_techniques": {
              "type": "array",
              "items": { "type": "string" }
            },
            "ai_sentence_pattern_details": {
              "type": "array",
              "description": "AI 句式原型命中详情",
              "items": {
                "type": "object",
                "properties": {
                  "pattern_name": { "type": "string", "enum": ["author_proxy_comprehension", "template_transition", "abstract_judgment", "formal_tone_intrusion"] },
                  "count": { "type": "integer", "minimum": 0 },
                  "examples": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "blacklist_update_suggestions": { "type": "array" }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["judges", "gate"],
      "properties": {
        "judges": {
          "type": "object",
          "required": ["primary", "overall_final"],
          "properties": {
            "primary": {
              "type": "object",
              "required": ["model", "overall", "overall_raw"],
              "properties": {
                "model": { "type": "string" },
                "overall": { "type": "number" },
                "overall_raw": { "type": "number" },
                "overall_weighted": { "type": ["number", "null"] }
              }
            },
            "secondary": {
              "type": "object",
              "properties": {
                "model": { "type": "string" },
                "overall": { "type": "number" },
                "overall_raw": { "type": "number" },
                "overall_weighted": { "type": ["number", "null"] }
              }
            },
            "used": { "type": "string", "enum": ["primary", "secondary"] },
            "overall_final": { "type": "number", "minimum": 1, "maximum": 5 }
          }
        },
        "gate": {
          "type": "object",
          "required": ["decision"],
          "properties": {
            "decision": { "enum": ["pass", "polish", "revise", "pause_for_user", "pause_for_user_force_rewrite"] },
            "revisions": { "type": "integer", "minimum": 0 },
            "force_passed": { "type": "boolean" }
          }
        }
      }
    }
  }
}
